POSTGRES_DB=fovea
POSTGRES_USER=fovea
POSTGRES_PASSWORD=fovea

FOVEA_PORT=8080
DATABASE_URL=postgresql+asyncpg://fovea:fovea@postgres:5432/fovea

ASSETS_PATH=/data/fovea/assets
MEDIA_PATH=./media

WEB_ORIGIN=http://localhost:5173
RENAME_DETECTION=partial_hash
FILESYSTEM_WATCHER_ENABLED=true
WATCH_DEBOUNCE_SECONDS=2.0
